<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened-runtime builds block microphone access unless the
	     audio-input entitlement is present. The monitor path (input
	     meter, latency probe, feedback capture) needs the mic. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
